{
  "$schema": "https://raw.githubusercontent.com/jetify-com/devbox/latest/.schema/devbox.schema.json",
  "packages": [
    "gh@latest",
    "cosign@latest",
    "shellcheck@latest",
    "shfmt@latest",
    "just@latest"
  ],
  "shell": {
    "init_hook": [
      "echo 'WhiteBlossom OS dev environment ready' > /dev/null"
    ],
    "scripts": {
      "build": [
        "just build"
      ],
      "lint": [
        "just lint"
      ],
      "format": [
        "just format"
      ],
      "check": [
        "just check"
      ]
    }
  }
}
